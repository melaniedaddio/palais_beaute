# =============================================================================
# CONFIGURATION ENVIRONNEMENT - Le Palais de la Beauté
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs appropriées
# Ne JAMAIS commiter le fichier .env (il contient des secrets)
# =============================================================================

# =============================================================================
# SÉCURITÉ
# =============================================================================

# Mode debug (True pour développement, False pour production)
DEBUG=False

# Clé secrète Django (générer une nouvelle clé pour la production)
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=votre-cle-secrete-ici-a-generer

# Hôtes autorisés (séparés par des virgules, sans espaces)
# Local      : localhost,127.0.0.1
# Production : palaisdelabeaute.ci,www.palaisdelabeaute.ci
ALLOWED_HOSTS=localhost,127.0.0.1

# Origines CSRF de confiance (séparées par des virgules, sans espaces)
# Local      : http://127.0.0.1:8000,http://localhost:8000
# Production : https://palaisdelabeaute.ci,https://www.palaisdelabeaute.ci
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Redirection HTTPS (False en développement, True quand le certificat SSL est configuré)
SECURE_SSL_REDIRECT=False

# =============================================================================
# BASE DE DONNÉES
# =============================================================================

# --- Option 1 : SQLite (développement local, aucune installation requise) ---
# DB_ENGINE=django.db.backends.sqlite3
# (laisser DB_NAME vide pour utiliser db.sqlite3 à la racine du projet)

# --- Option 2 : PostgreSQL (production) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=palais_beaute
DB_USER=votre_user
DB_PASSWORD=votre_password
DB_HOST=localhost
DB_PORT=5432
