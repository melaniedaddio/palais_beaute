# Configuration Django - Le Palais de la Beauté
# Copiez ce fichier en .env et remplissez avec vos valeurs réelles

# SÉCURITÉ
# Générez une nouvelle clé secrète avec: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=votre-cle-secrete-ici-a-generer

# MODE DEBUG (True pour développement, False pour production)
DEBUG=False

# HOSTS AUTORISÉS (séparés par des virgules)
# Exemple: monsite.com,www.monsite.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ORIGINES CSRF DE CONFIANCE (séparées par des virgules)
# Exemple: https://monsite.com,https://www.monsite.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# BASE DE DONNÉES (optionnel - par défaut SQLite)
# Pour PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=palais_beaute
# DB_USER=votre_user
# DB_PASSWORD=votre_password
# DB_HOST=localhost
# DB_PORT=5432
